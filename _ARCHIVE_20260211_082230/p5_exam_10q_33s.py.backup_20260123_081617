        st.markdown("</div>", unsafe_allow_html=True)

    with right:
        st.markdown("<div class='ex10-colcard'>", unsafe_allow_html=True)
        st.markdown("<div class='ex10-coltitle'>💥 Q2 · FINISH (Meaning)</div>", unsafe_allow_html=True)
        if q2_prompt:
            st.caption(q2_prompt)

        if not (isinstance(q2_choices, list) and len(q2_choices) == 4 and q2_answer):
            _fail(f"Invalid Q2 data: Set{set_idx+1}")
            _rerun()
            st.stop()

        st.markdown("<div class='ex10-q2'>", unsafe_allow_html=True)
        q2_done = bool(st.session_state.get("ex10_q2_done", False))
        for i, opt in enumerate(q2_choices):
            if st.button(f"{labels[i]} {opt}".strip(), use_container_width=True, key=f"ex10_s{set_idx}_q2_{i}", disabled=q2_done):
                if str(opt).strip() != q2_answer:
                    _fail(f"Wrong: Set{set_idx+1}-Q2")
                    _rerun()
                    st.stop()
                st.session_state["ex10_score"] = int(st.session_state["ex10_score"]) + 1
                st.session_state["ex10_q2_done"] = True
                _rerun()
                st.stop()
        st.markdown("</div>", unsafe_allow_html=True)
        if q2_done:
            st.success("Q2 ✅")
        st.markdown("</div>", unsafe_allow_html=True)

    if bool(st.session_state.get("ex10_q1_done", False)) and bool(st.session_state.get("ex10_q2_done", False)):
        st.session_state["ex10_set_idx"] = set_idx + 1
        st.session_state["ex10_q1_done"] = False
        st.session_state["ex10_q2_done"] = False
        _rerun()
        st.stop()
