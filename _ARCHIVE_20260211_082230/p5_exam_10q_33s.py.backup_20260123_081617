def _load_word_bank() -> Dict[str, Any]:
    path = os.path.join("data", "word_bank.json")
    if not os.path.exists(path):
        return {}
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, dict):
            data.pop("_meta", None)
            return data
    except Exception:
        return {}
    return {}


def _tokenize(text: str) -> List[str]:
    return re.findall(r"[a-zA-Z]+", text.lower())


def _p5_items(items: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    return [x for x in items if isinstance(x, dict) and x.get("source") == "P5"]


def _pick_str(q: Dict[str, Any], keys: List[str], default: str = "") -> str:
    for k in keys:
        v = q.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip()
    return default


def _find_phrase_targets(sentence_l: str, bank: Dict[str, Any]) -> List[str]:
    phrases = [
        k for k, v in bank.items()
        if isinstance(k, str) and " " in k and isinstance(v, dict) and v.get("kind") == "phrase"
    ]
    return [ph for ph in phrases if ph in sentence_l]


def _find_word_targets(sentence: str, bank: Dict[str, Any]) -> List[str]:
    toks = _tokenize(sentence)
    hits: List[str] = []
    for t in toks:
        v = bank.get(t)
        if isinstance(v, dict) and v.get("kind") == "word":
            hits.append(t)
    return list(dict.fromkeys(hits))


def _pick_target(sentence: str, bank: Dict[str, Any]) -> Tuple[str, str]:
    s_l = sentence.lower()
    ph_hits = _find_phrase_targets(s_l, bank)
    if ph_hits:
        return random.choice(ph_hits), "phrase"
    w_hits = _find_word_targets(sentence, bank)
    if w_hits:
        w_hits.sort(key=len, reverse=True)
        return w_hits[0], "word"
    return "", "word"


def _make_q2(target: str, kind: str, bank: Dict[str, Any]) -> Dict[str, Any]:
    entry = bank.get(target)
    if not isinstance(entry, dict):
        return {}
    ko_correct = str(entry.get("ko_correct", "")).strip()
    ko_wrongs = entry.get("ko_wrongs", [])
    if not (ko_correct and isinstance(ko_wrongs, list) and len(ko_wrongs) >= 3):
        return {}
    prompt = "Meaning of the blinking phrase?" if kind == "phrase" else "Meaning of the blinking word?"
    choices = [ko_correct] + [str(x) for x in ko_wrongs[:3]]
    random.shuffle(choices)
    return {"prompt": prompt, "choices": choices, "answer": ko_correct}


def _blink_once(sentence: str, target: str, kind: str) -> str:
    if not target:
        return sentence
    if kind == "phrase":
        pattern = re.compile(re.escape(target), re.IGNORECASE)
        return pattern.sub(lambda m: f"<span class='ex10-blink'>{m.group(0)}</span>", sentence, count=1)
    pattern = re.compile(rf"\b{re.escape(target)}\b", re.IGNORECASE)
    return pattern.sub(lambda m: f"<span class='ex10-blink'>{m.group(0)}</span>", sentence, count=1)


def _init_state() -> None:
    ss = st.session_state
    ss.setdefault("ex10_active", False)
    ss.setdefault("ex10_start", 0.0)
    ss.setdefault("ex10_done", False)
    ss.setdefault("ex10_fail_reason", "")
    ss.setdefault("ex10_score", 0)
    ss.setdefault("ex10_pack", [])
    ss.setdefault("ex10_set_idx", 0)
    ss.setdefault("ex10_q1_done", False)
    ss.setdefault("ex10_q2_done", False)


def _reset() -> None:
    for k in list(st.session_state.keys()):
        if k.startswith("ex10_"):
            del st.session_state[k]
    _init_state()


def _remain() -> int:
    start = float(st.session_state.get("ex10_start", 0.0) or 0.0)
    if start <= 0:
        return TIME_LIMIT
    return int(TIME_LIMIT - (time.time() - start))


def _fail(reason: str) -> None:
    st.session_state["ex10_done"] = True
    st.session_state["ex10_active"] = False
    st.session_state["ex10_fail_reason"] = reason


def _success() -> None:
    st.session_state["ex10_done"] = True
    st.session_state["ex10_active"] = False
    st.session_state["ex10_fail_reason"] = ""


def _start_game() -> None:
    bank = _load_word_bank()
    if not bank:
        _fail("Word Bank not found or empty: data/word_bank.json")
        return

    items = armory._load_armory_items()  # type: ignore[attr-defined]
    p5 = _p5_items(items)
    if len(p5) < SETS:
        _fail(f"Not enough P5 items in armory: {len(p5)} (need {SETS})")
        return

    eligible: List[Dict[str, Any]] = []
    for q in p5:
        sentence = _pick_str(q, ["sentence", "q", "question"], "")
        if not sentence:
            continue

        target, kind = _pick_target(sentence, bank)
        if not target:
            continue

        q2 = _make_q2(target, kind, bank)
        if not q2:
            continue

        sent_blink = _blink_once(sentence, target, kind)

        choices = list(q.get("choices", []) or [])[:4]
        while len(choices) < 4:
            choices.append("")

        eligible.append({
            "sentence": sentence,
            "choices": choices,
            "answer": _pick_str(q, ["answer", "correct", "correct_answer", "ans"], ""),
            "q2": q2,
            "sentence_blink_html": sent_blink,
        })

    if len(eligible) < SETS:
        _fail(f"Q2 탄약 부족: Word Bank 매칭 문장이 {len(eligible)}개입니다. (최소 {SETS}개 필요)")
        return

    pack = random.sample(eligible, SETS)

    st.session_state["ex10_pack"] = pack
    st.session_state["ex10_active"] = True
    st.session_state["ex10_done"] = False
    st.session_state["ex10_fail_reason"] = ""
    st.session_state["ex10_start"] = time.time()
    st.session_state["ex10_score"] = 0
    st.session_state["ex10_set_idx"] = 0
    st.session_state["ex10_q1_done"] = False
    st.session_state["ex10_q2_done"] = False


