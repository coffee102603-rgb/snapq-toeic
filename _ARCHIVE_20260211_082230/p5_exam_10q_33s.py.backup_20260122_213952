# ============================================================
# Data helpers
# ============================================================
def _load_word_bank() -> Dict[str, Any]:
    path = os.path.join("data", "word_bank.json")
    if not os.path.exists(path):
        return {}
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, dict):
            data.pop("_meta", None)
            return data
    except Exception:
        return {}
    return {}


def _tokenize(text: str) -> List[str]:
    return re.findall(r"[a-zA-Z]+", text.lower())


def _p5_items(items: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    return [x for x in items if isinstance(x, dict) and x.get("source") == "P5"]


def _pick_str(q: Dict[str, Any], keys: List[str], default: str = "") -> str:
    for k in keys:
        v = q.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip()
    return default


def _find_phrase_targets(sentence_l: str, bank: Dict[str, Any]) -> List[str]:
    phrases = [
        k for k, v in bank.items()
        if isinstance(k, str) and " " in k and isinstance(v, dict) and v.get("kind") == "phrase"
    ]
    return [ph for ph in phrases if ph in sentence_l]


def _find_word_targets(sentence: str, bank: Dict[str, Any]) -> List[str]:
    toks = _tokenize(sentence)
    hits: List[str] = []
    for t in toks:
        v = bank.get(t)
        if isinstance(v, dict) and v.get("kind") == "word":
            hits.append(t)
    return list(dict.fromkeys(hits))


def _pick_target(sentence: str, bank: Dict[str, Any]) -> Tuple[str, str]:
    s_l = sentence.lower()
    ph_hits = _find_phrase_targets(s_l, bank)
    if ph_hits:
        return random.choice(ph_hits), "phrase"
    w_hits = _find_word_targets(sentence, bank)
    if w_hits:
        w_hits.sort(key=len, reverse=True)
        return w_hits[0], "word"
    return "", "word"


def _make_q2(target: str, kind: str, bank: Dict[str, Any]) -> Dict[str, Any]:
    entry = bank.get(target)
    if not isinstance(entry, dict):
        return {}
    ko_correct = str(entry.get("ko_correct", "")).strip()
    ko_wrongs = entry.get("ko_wrongs", [])
    if not (ko_correct and isinstance(ko_wrongs, list) and len(ko_wrongs) >= 3):
        return {}
    prompt = "Meaning of the blinking phrase?" if kind == "phrase" else "Meaning of the blinking word?"
    choices = [ko_correct] + [str(x) for x in ko_wrongs[:3]]
    random.shuffle(choices)
    return {"prompt": prompt, "choices": choices, "answer": ko_correct}


def _blink_once(sentence: str, target: str, kind: str) -> str:
    if not target:
        return sentence
    if kind == "phrase":
        pattern = re.compile(re.escape(target), re.IGNORECASE)
        return pattern.sub(lambda m: f"<span class='ex10-blink'>{m.group(0)}</span>", sentence, count=1)
    pattern = re.compile(rf"\b{re.escape(target)}\b", re.IGNORECASE)
    return pattern.sub(lambda m: f"<span class='ex10-blink'>{m.group(0)}</span>", sentence, count=1)


# ============================================================
# Game State
# ============================================================
def _init_state() -> None:
    ss = st.session_state
    ss.setdefault("ex10_active", False)
    ss.setdefault("ex10_start", 0.0)
    ss.setdefault("ex10_done", False)
    ss.setdefault("ex10_fail_reason", "")
    ss.setdefault("ex10_score", 0)
    ss.setdefault("ex10_pack", [])
    ss.setdefault("ex10_set_idx", 0)
    ss.setdefault("ex10_q1_done", False)
    ss.setdefault("ex10_q2_done", False)


def _reset() -> None:
    for k in list(st.session_state.keys()):
        if k.startswith("ex10_"):
            del st.session_state[k]
    _init_state()


def _remain() -> int:
    start = float(st.session_state.get("ex10_start", 0.0) or 0.0)
    if start <= 0:
        return TIME_LIMIT
    return int(TIME_LIMIT - (time.time() - start))


def _fail(reason: str) -> None:
    st.session_state["ex10_done"] = True
    st.session_state["ex10_active"] = False
    st.session_state["ex10_fail_reason"] = reason


def _success() -> None:
    st.session_state["ex10_done"] = True
    st.session_state["ex10_active"] = False
    st.session_state["ex10_fail_reason"] = ""


def _start_game() -> None:
    bank = _load_word_bank()
    if not bank:
        _fail("Word Bank not found or empty: data/word_bank.json")
        return

    items = armory._load_armory_items()  # type: ignore[attr-defined]
    p5 = _p5_items(items)
    if len(p5) < SETS:
        _fail(f"Not enough P5 items in armory: {len(p5)} (need {SETS})")
        return

    eligible: List[Dict[str, Any]] = []
    for q in p5:
        sentence = _pick_str(q, ["sentence", "q", "question"], "")
        if not sentence:
            continue

        target, kind = _pick_target(sentence, bank)
        if not target:
            continue

        q2 = _make_q2(target, kind, bank)
        if not q2:
            continue

        sent_blink = _blink_once(sentence, target, kind)

        choices = list(q.get("choices", []) or [])[:4]
        while len(choices) < 4:
            choices.append("")

        eligible.append({
            "sentence": sentence,
            "choices": choices,
            "answer": _pick_str(q, ["answer", "correct", "correct_answer", "ans"], ""),
            "q2": q2,
            "sentence_blink_html": sent_blink,
        })

    if len(eligible) < SETS:
        _fail(f"Q2 탄약 부족: Word Bank 매칭 문장이 {len(eligible)}개입니다. (최소 {SETS}개 필요)")
        return

    pack = random.sample(eligible, SETS)

    st.session_state["ex10_pack"] = pack
    st.session_state["ex10_active"] = True
    st.session_state["ex10_done"] = False
    st.session_state["ex10_fail_reason"] = ""
    st.session_state["ex10_start"] = time.time()
    st.session_state["ex10_score"] = 0
    st.session_state["ex10_set_idx"] = 0
    st.session_state["ex10_q1_done"] = False
    st.session_state["ex10_q2_done"] = False


# ============================================================
# Main Render
# ============================================================
def render() -> None:
    _init_state()
    _inject_css()

    remain = max(0, _remain())
    timer_cls = ""
    if remain <= 15:
        timer_cls = "danger"
    if remain <= 8:
        timer_cls = "critical"

    st.markdown(
        f"""
        <div class="ex10-hud">
          <div class="ex10-title">🔥 P5 EXAM · 10Q / 33s</div>
          <div class="ex10-timer {timer_cls}">💣 {remain}s</div>
        </div>
        """,
        unsafe_allow_html=True,
    )

    if st.session_state.get("ex10_done", False):
        score = int(st.session_state.get("ex10_score", 0))
        reason = str(st.session_state.get("ex10_fail_reason", "")).strip()

        if reason:
            st.markdown("<div class='ex10-fail'>❌ FAIL (Sudden Death)</div>", unsafe_allow_html=True)
            st.write(reason)
        else:
            st.success("✅ CLEAR! (Perfect run)")

        st.markdown(f"### Score: {score} / {TOTAL_Q}")

        c1, c2 = st.columns(2)
        with c1:
            if st.button("🔁 Retry", use_container_width=True, key="ex10_retry_btn"):
                _reset()
                _rerun()
                st.stop()
        with c2:
            if st.button("🏠 Hub", use_container_width=True, key="ex10_hub_btn"):
                _go_hub()
        st.stop()

    if not st.session_state.get("ex10_active", False):
        st.markdown(
            """
            <div style="background:rgba(20,25,45,.72);border:1px solid rgba(255,255,255,.16);
                        border-radius:16px;padding:14px 16px;box-shadow:0 18px 40px rgba(0,0,0,.22);color:#fff;">
              <div style="font-weight:950;font-size:18px;">🧨 RULES</div>
              <div style="margin-top:6px;line-height:1.6;">
                • 5 sets (Q1 + Q2 on ONE screen)<br>
                • 33 seconds total
              </div>
              <div style="margin-top:10px;font-weight:950;">☠️ Sudden Death</div>
              <div style="line-height:1.6;">
                • Any wrong answer → FAIL<br>
                • Time over → FAIL
              </div>
              <div style="opacity:.85;margin-top:8px;">Q2: Meaning of the blinking word/phrase (Korean choices)</div>
            </div>
            """,
            unsafe_allow_html=True,
        )
        st.markdown("<div style='height:12px'></div>", unsafe_allow_html=True)
        if st.button("🚀 Start", use_container_width=True, key="ex10_start_btn"):
            _start_game()
            _rerun()
            st.stop()
        st.stop()

    if remain <= 0:
        _fail("Time over (33s)")
        _rerun()
        st.stop()

    pack: List[Dict[str, Any]] = st.session_state.get("ex10_pack", [])
    set_idx = int(st.session_state.get("ex10_set_idx", 0))

    if set_idx >= SETS:
        if int(st.session_state.get("ex10_score", 0)) == TOTAL_Q:
            _success()
        else:
            _fail("Not perfect (must be 10/10)")
        _rerun()
        st.stop()

    q = pack[set_idx]
    sent_blink_html = str(q.get("sentence_blink_html", q.get("sentence", "")))

    q1_choices = list(q.get("choices", []) or [])[:4]
    q1_answer = str(q.get("answer", "")).strip()

    q2 = q.get("q2", {}) or {}
    q2_prompt = str(q2.get("prompt", "")).strip()
    q2_choices = q2.get("choices", []) or []
    q2_answer = str(q2.get("answer", "")).strip()

    st.markdown(
        f"""
        <div class="ex10-paper">
          <div class="ex10-meta">Set {set_idx+1}/{SETS} · (Q1 + Q2)</div>
          <div class="ex10-sent">{sent_blink_html}</div>
        </div>
        """,
        unsafe_allow_html=True,
    )
    st.markdown("<div style='height:14px'></div>", unsafe_allow_html=True)

    left, right = st.columns(2, gap="large")
    labels = ["(A)", "(B)", "(C)", "(D)"]

    with left:
        st.markdown("<div class='ex10-colcard'>", unsafe_allow_html=True)
        st.markdown("<div class='ex10-coltitle'>Q1 · Grammar</div>", unsafe_allow_html=True)

        st.markdown("<div class='ex10-q1'>", unsafe_allow_html=True)
        q1_done = bool(st.session_state.get("ex10_q1_done", False))
        for i, opt in enumerate(q1_choices[:4]):
            if st.button(
                f"{labels[i]} {opt}".strip(),
                use_container_width=True,
                key=f"ex10_s{set_idx}_q1_{i}",
                disabled=q1_done,
            ):
                if opt.strip() != q1_answer:
                    _fail(f"Wrong: Set{set_idx+1}-Q1")
                    _rerun()
                    st.stop()
                st.session_state["ex10_score"] = int(st.session_state["ex10_score"]) + 1
                st.session_state["ex10_q1_done"] = True
                _rerun()
                st.stop()
        st.markdown("</div>", unsafe_allow_html=True)

        if q1_done:
            st.success("Q1 ✅")
        st.markdown("</div>", unsafe_allow_html=True)

    with right:
        st.markdown("<div class='ex10-colcard'>", unsafe_allow_html=True)
        st.markdown("<div class='ex10-coltitle'>Q2 · Meaning</div>", unsafe_allow_html=True)
        if q2_prompt:
            st.caption(q2_prompt)

        if not (isinstance(q2_choices, list) and len(q2_choices) == 4 and q2_answer):
            _fail(f"Invalid Q2 data: Set{set_idx+1}")
            _rerun()
            st.stop()

        st.markdown("<div class='ex10-q2'>", unsafe_allow_html=True)
        q2_done = bool(st.session_state.get("ex10_q2_done", False))
        for i, opt in enumerate(q2_choices):
            if st.button(
                f"{labels[i]} {opt}".strip(),
                use_container_width=True,
                key=f"ex10_s{set_idx}_q2_{i}",
                disabled=q2_done,
            ):
                if str(opt).strip() != q2_answer:
                    _fail(f"Wrong: Set{set_idx+1}-Q2")
                    _rerun()
                    st.stop()
                st.session_state["ex10_score"] = int(st.session_state["ex10_score"]) + 1
                st.session_state["ex10_q2_done"] = True
                _rerun()
                st.stop()
        st.markdown("</div>", unsafe_allow_html=True)

        if q2_done:
            st.success("Q2 ✅")
        st.markdown("</div>", unsafe_allow_html=True)

    if bool(st.session_state.get("ex10_q1_done", False)) and bool(st.session_state.get("ex10_q2_done", False)):
        st.session_state["ex10_set_idx"] = set_idx + 1
        st.session_state["ex10_q1_done"] = False
        st.session_state["ex10_q2_done"] = False
        _rerun()
        st.stop()
