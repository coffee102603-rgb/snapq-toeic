# =========================================================
# HUD helpers
# =========================================================
def _hud_attend_text() -> str:
    v = st.session_state.get("attend_status")
    if isinstance(v, str) and v.strip():
        return v.strip()
    if st.session_state.get("attended_today") is True:
        return "ATTEND · DONE"
    return "ATTEND · READY"


def _hud_mission_text() -> str:
    v = st.session_state.get("mission_status")
    if isinstance(v, str) and v.strip():
        return v.strip()
    return "MISSION · READY"


def _hud_today_text() -> str:
    minutes = st.session_state.get("today_minutes")
    runs = st.session_state.get("today_runs")
    try:
        m = float(minutes) if minutes is not None else 0.0
    except Exception:
        m = 0.0
    try:
        r = int(runs) if runs is not None else 0
    except Exception:
        r = 0
    return f"TODAY · {m:.1f}m · {r}x"


# =========================================================
# Public API
# =========================================================
def require_access(
    context_tag: str = "ACCESS",
    roster_path: str = r"data\cohorts\2026-01\roster.json",
) -> str:

    if st.session_state.get("access_granted") and st.session_state.get("battle_nickname"):
        return st.session_state["battle_nickname"]

    ctx = (context_tag or "").strip().upper()
    if ctx in {"ACCESS", "NICKNAME", "ACCESS_GUARD"} and _in_post_window():
        try:
            from app.core.posttest_gate import require_posttest_gate
            require_posttest_gate(context_tag=context_tag)
        except Exception:
            pass

    apply_access_lobby_theme()
    roster = _load_roster(roster_path)

    st.markdown('<div class="access-wrap">', unsafe_allow_html=True)

    st.markdown(
        f"""
        <div class="hud-row">
          <div class="hud-left">
            <div class="hud-chip">🪪 <b>MISSION ACCESS</b></div>
            <div class="hud-chip dim">✅ <b>{_hud_attend_text()}</b></div>
            <div class="hud-chip dim">🎯 <b>{_hud_mission_text()}</b></div>
            <div class="hud-chip dim">⏱️ <b>{_hud_today_text()}</b></div>
          </div>
          <div class="hud-chip">🔥 <b>SnapQ TOEIC · READY</b></div>
        </div>
        """,
        unsafe_allow_html=True,
    )

    st.markdown('<div class="access-card">', unsafe_allow_html=True)

    st.markdown('<div class="access-title">배틀 ID 인증</div>', unsafe_allow_html=True)
    st.markdown(
        '<div class="access-subtitle">코드네임 입력 → 출격. (대소문자/언더바(_)만 주의)</div>',
        unsafe_allow_html=True,
    )
    st.markdown('<div class="access-stripe"></div>', unsafe_allow_html=True)

    st.markdown('<div class="access-grid">', unsafe_allow_html=True)

    st.markdown('<div class="panel">', unsafe_allow_html=True)
    st.markdown('<div class="panel-label">코드네임</div>', unsafe_allow_html=True)

    # ✅ placeholder 제거: “예: 850_ABD” 절대 표시 안 함
    nickname = st.text_input(
        label="코드네임",
        value=st.session_state.get("pending_nickname", ""),
        placeholder="",  # ← 핵심
        key="access_nickname_input",
    )
    st.session_state["pending_nickname"] = nickname

    st.markdown('<div class="btn-grid">', unsafe_allow_html=True)
    c1, c2 = st.columns(2, gap="large")

    with c1:
        st.markdown('<div class="primary-btn">', unsafe_allow_html=True)
        go = st.button("🚀 출격 (ENTER)", key="access_enter_btn", use_container_width=True)
        st.markdown("</div>", unsafe_allow_html=True)

    with c2:
        reset = st.button("🔁 재장전 (RESET)", key="access_reset_btn", use_container_width=True)

    st.markdown("</div>", unsafe_allow_html=True)  # btn-grid
    st.markdown("</div>", unsafe_allow_html=True)  # panel

    st.markdown(
        """
        <div class="mini-card">
          <div class="mini-title">🎮 출격 규칙</div>
          <div class="mini-line">• <b>등록된 코드네임</b>만 입장 가능</div>
          <div class="mini-line">• 오타 나면 <b>RESET</b> → 다시 출격</div>
          <div class="mini-line">• 기억 안 나면 교관에게 “<b>코드네임 재발급</b>” 요청</div>
        </div>
        """,
        unsafe_allow_html=True,
    )

    st.markdown("</div>", unsafe_allow_html=True)  # access-grid
    st.markdown("</div>", unsafe_allow_html=True)  # access-card
    st.markdown("</div>", unsafe_allow_html=True)  # access-wrap

    if reset:
        st.session_state["pending_nickname"] = ""
        st.session_state["access_nickname_input"] = ""
        _toast("🔁 재장전 완료. 다시 입력하세요.")
        _rerun()

    if go:
        nick = _normalize_nickname(nickname)
        if not nick:
            st.warning("코드네임을 입력하세요.")
            st.stop()

        if _is_registered(nick, roster):
            st.session_state["battle_nickname"] = nick
            st.session_state["access_granted"] = True
            st.session_state["access_context_tag"] = context_tag
            _toast("✅ 인증 완료! 로비로 이동합니다.")
            _rerun()
        else:
            st.error("❌ 미등록 코드네임입니다. 철자/대소문자/언더바(_)를 확인하세요.")
            st.stop()

    st.stop()
