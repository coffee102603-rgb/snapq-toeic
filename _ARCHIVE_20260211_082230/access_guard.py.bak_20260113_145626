from __future__ import annotations

import json
from pathlib import Path
from datetime import datetime
from typing import Any, Iterable, Set

import streamlit as st


# =========================================================
# Time helpers
# =========================================================
def _now_kst_date():
    return datetime.now().date()


def _today_day() -> int:
    return _now_kst_date().day


def _in_post_window(day: int | None = None) -> bool:
    d = day if day is not None else _today_day()
    return 21 <= int(d) <= 25


# =========================================================
# Streamlit compat (rerun safe)
# =========================================================
def _rerun():
    if hasattr(st, "rerun"):
        st.rerun()
        return
    if hasattr(st, "experimental_rerun"):
        st.experimental_rerun()
        return
    st.session_state["_force_rerun_toggle"] = not st.session_state.get("_force_rerun_toggle", False)
    st.stop()


def _toast(msg: str):
    if hasattr(st, "toast"):
        st.toast(msg)


# =========================================================
# JSON / roster parsing (HARDENED)
# =========================================================
def _read_json(path: Path) -> Any:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _normalize_nickname(s: str) -> str:
    return (s or "").strip()


def _load_roster(roster_path: str) -> Any:
    return _read_json(Path(roster_path))


def _iter_strings(obj: Any) -> Iterable[str]:
    if obj is None:
        return
    if isinstance(obj, str):
        yield obj
        return
    if isinstance(obj, (int, float, bool)):
        return
    if isinstance(obj, (list, tuple, set)):
        for x in obj:
            yield from _iter_strings(x)
        return
    if isinstance(obj, dict):
        for k, v in obj.items():
            if isinstance(k, str):
                yield k
            yield from _iter_strings(v)
        return


def _collect_candidates(roster_data: Any) -> Set[str]:
    raw: Set[str] = set()
    for s in _iter_strings(roster_data):
        s2 = s.strip()
        if s2:
            raw.add(s2)
    return raw


def _is_registered(nickname: str, roster_data: Any) -> bool:
    nick = _normalize_nickname(nickname)
    if not nick:
        return False

    candidates = _collect_candidates(roster_data)

    if nick in candidates:
        return True

    low = {c.lower() for c in candidates}
    if nick.lower() in low:
        return True

    return False


